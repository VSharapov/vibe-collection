   if [[ "$http_code" -ge 400 ]]; then
-    >&2 echo "error: API returned $http_code"
+    >&2 echo "error: $method $url returned $http_code"
     >&2 echo "$response" | jq -r '.message // .error // .' 2>/dev/null || >&2 echo "$response"
