+external-ip() {
+  local ip
+  ip=$(dig +short txt ch whoami.cloudflare @1.1.1.1 2>/dev/null | sed 's/"//g') && [[ -n "$ip" ]] && { echo "$ip"; return; }
+  ip=$(dig @ns1.google.com TXT o-o.myaddr.l.google.com +short 2>/dev/null | sed 's/"//g') && [[ -n "$ip" ]] && { echo "$ip"; return; }
+  ip=$(curl -s --max-time 5 http://whatismyip.akamai.com 2>/dev/null) && [[ -n "$ip" ]] && { echo "$ip"; return; }
+  ip=$(curl -s --max-time 5 https://api.ipify.org 2>/dev/null) && [[ -n "$ip" ]] && { echo "$ip"; return; }
+  ip=$(curl -s --max-time 5 ifconfig.me 2>/dev/null) && [[ -n "$ip" ]] && { echo "$ip"; return; }
+  ip=$(curl -s --max-time 5 icanhazip.com 2>/dev/null) && [[ -n "$ip" ]] && { echo "$ip"; return; }
+  >&2 echo "error: could not determine external IP"
+  exit 1
+}
